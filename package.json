    "cypress": "^15.18.0",
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.6.0",
    "jsdom": "^29.1.1",
    "terser": "^5.48.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.0",
