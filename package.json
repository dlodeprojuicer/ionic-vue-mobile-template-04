    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/status-bar": "^8.0.2",
    "@ionic/vue": "^8.8.12",
    "@ionic/vue-router": "^8.8.12",
    "ionicons": "^8.0.13",
    "sass": "^1.101.0",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^10.0.0",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-legacy": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-dom": "^3.5.39",
    "@vue/eslint-config-typescript": "^14.9.0",
