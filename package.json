{
  "name": "ionic-vue-mobile-template-01",
  "description": "Hybrid app template built with vue, ionic and capacitor",
  "author": "Simo Mafuxwana - @dlodeprojuicer",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "vite --host 0.0.0.0",
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:e2e": "cypress run",
    "lint": "eslint ."
  },
  "dependencies": {
